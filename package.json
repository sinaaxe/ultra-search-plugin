{
	"name": "obsidian-ultra-search",
	"version": "1.5.3",
	"description": "Fuzzy, out-of-order, and typo-tolerant search across file names and line contents with color-coded navigation in Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"search",
		"fuzzy",
		"granular",
		"block",
		"line"
	],
	"author": "Antigravity",
	"license": "MIT",
	"dependencies": {
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@types/node": "^25.9.2",
		"esbuild": "^0.28.0",
		"obsidian": "^1.13.1",
		"typescript": "^6.0.3"
	}
}